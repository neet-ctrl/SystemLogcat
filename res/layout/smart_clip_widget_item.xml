<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/smart_clip_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="6dp"
    android:paddingTop="9dp"
    android:paddingBottom="9dp"
    android:background="@drawable/widget_item_a">

    <!-- #N serial chip -->
    <TextView
        android:id="@+id/tv_serial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="#1"
        android:textSize="9sp"
        android:textColor="#FF818CF8"
        android:textStyle="bold"
        android:background="@drawable/widget_btn_inactive"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_marginEnd="8dp"/>

    <!-- Content / description -->
    <TextView
        android:id="@+id/clip_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#FFE2E8F0"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.2"/>

    <!-- 📌/📍 Pin icon button -->
    <Button
        android:id="@+id/btn_pin"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="📍"
        android:textSize="12sp"
        android:background="@drawable/widget_copy_chip"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:layout_marginStart="6dp"/>

    <!-- 📋 Copy icon button -->
    <Button
        android:id="@+id/btn_copy"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="📋"
        android:textSize="12sp"
        android:background="@drawable/widget_copy_chip"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:layout_marginStart="6dp"/>

</LinearLayout>
