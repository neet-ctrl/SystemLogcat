<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_glass_bg"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- ── Glassy Header ─────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_header_bg"
        android:paddingStart="14dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tv_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Clipboard History"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#FFFFFFFF"/>

        <!-- 🔐 Smart Clips mode toggle pill -->
        <Button
            android:id="@+id/btn_mode_smart"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="🔐 Smart"
            android:textSize="9sp"
            android:textColor="#FFCDD5FF"
            android:background="@drawable/widget_btn_inactive"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:minHeight="0dp"/>

        <!-- ⬡ Float overlay button -->
        <Button
            android:id="@+id/btn_floating"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="⬡"
            android:textSize="13sp"
            android:textColor="#FFAAB4FF"
            android:background="@drawable/widget_btn_inactive"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="4dp"/>

        <!-- ↺ Refresh button -->
        <Button
            android:id="@+id/btn_refresh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="↺"
            android:textSize="14sp"
            android:textColor="#FFAAB4FF"
            android:background="@drawable/widget_btn_inactive"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"/>

    </LinearLayout>

    <!-- ── Clip List ──────────────────────────────────────── -->
    <ListView
        android:id="@+id/clip_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:clipToPadding="false"/>

</LinearLayout>
