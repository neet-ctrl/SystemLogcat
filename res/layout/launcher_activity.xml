<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/launcher_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

  <ScrollView
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:fillViewport="true"
      android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

      <!-- ═══ HEADER BANNER ══════════════════════════════════════ -->
      <LinearLayout
          android:id="@+id/launcher_header"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:paddingStart="22dp"
          android:paddingEnd="16dp"
          android:paddingTop="24dp"
          android:paddingBottom="36dp"
          android:background="#FF4F46E5">

        <!-- Top row: brand + two icon buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

          <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UnBelievable"
                android:textColor="#FFFFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keyboard ✦"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"/>
          </LinearLayout>

          <!-- Existing keyboard settings gear → SettingsActivity -->
          <ImageButton
              android:id="@+id/btnLaunchSettingsActivity"
              android:layout_width="44dp"
              android:layout_height="44dp"
              android:src="@drawable/cog_outline"
              android:background="@drawable/dev_console_icon_btn"
              android:contentDescription="Keyboard Settings"
              android:padding="10dp"/>

          <!-- NEW app settings (tune/sliders) → AppSettingsActivity -->
          <ImageButton
              android:id="@+id/btn_app_settings"
              android:layout_width="44dp"
              android:layout_height="44dp"
              android:src="@drawable/ic_tune"
              android:background="@drawable/dev_console_icon_btn"
              android:contentDescription="App Settings"
              android:padding="10dp"
              android:layout_marginStart="6dp"/>

        </LinearLayout>

        <!-- Gesture animations -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="22dp">

          <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:orientation="vertical" android:gravity="center" android:layout_marginEnd="24dp">
            <ImageView android:id="@+id/launcher_anim_swipe" style="@style/anim"
                android:background="@drawable/doc_key_u" android:src="@drawable/doc_anim_swipe"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/launcher_anim_7" android:textColor="#AAFFFFFF"
                android:textSize="10sp" android:gravity="center" android:layout_marginTop="5dp"/>
          </LinearLayout>

          <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:orientation="vertical" android:gravity="center" android:layout_marginEnd="24dp">
            <ImageView android:id="@+id/launcher_anim_circle" style="@style/anim"
                android:background="@drawable/doc_key_g" android:src="@drawable/doc_anim_circle"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/launcher_anim_g" android:textColor="#AAFFFFFF"
                android:textSize="10sp" android:gravity="center" android:layout_marginTop="5dp"/>
          </LinearLayout>

          <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:orientation="vertical" android:gravity="center">
            <ImageView android:id="@+id/launcher_anim_round_trip" style="@style/anim"
                android:background="@drawable/doc_key_g" android:src="@drawable/doc_anim_round_trip"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/launcher_anim_dash" android:textColor="#AAFFFFFF"
                android:textSize="10sp" android:gravity="center" android:layout_marginTop="5dp"/>
          </LinearLayout>

        </LinearLayout>

      </LinearLayout>

      <!-- ═══ SETUP CARD (pulls up over the header) ══════════════ -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:paddingStart="16dp"
          android:paddingEnd="16dp"
          android:layout_marginTop="-18dp">

        <LinearLayout
            android:id="@+id/card_setup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="⌨  Enable Keyboard"
              android:id="@+id/tv_setup_title"
              android:textSize="12sp"
              android:textStyle="bold"
              android:paddingBottom="12dp"/>

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal">

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/launcher_button_imesettings"
                android:onClick="launch_imesettings"
                android:textSize="12sp"
                android:padding="12dp"/>

            <View android:layout_width="8dp" android:layout_height="1dp"/>

            <Button
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/launcher_button_imepicker"
                android:onClick="launch_imepicker"
                android:textSize="12sp"
                android:padding="12dp"/>

          </LinearLayout>

        </LinearLayout>

      </LinearLayout>

      <!-- ═══ FEATURE GRID ════════════════════════════════════════ -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:paddingStart="16dp"
          android:paddingEnd="16dp"
          android:layout_marginTop="10dp">

        <!-- Row 1: Clipboard | Smart Clips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

          <LinearLayout
              android:id="@+id/btn_clipboard_history"
              android:layout_width="0dp"
              android:layout_height="120dp"
              android:layout_weight="1"
              android:orientation="vertical"
              android:padding="18dp"
              android:gravity="center"
              android:clickable="true"
              android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📋" android:textSize="30sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Clipboard" android:textSize="13sp" android:textStyle="bold"
                android:layout_marginTop="7dp"/>
            <TextView android:id="@+id/tv_card_clipboard_sub"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="History" android:textSize="10sp" android:layout_marginTop="3dp"/>
          </LinearLayout>

          <View android:layout_width="10dp" android:layout_height="1dp"/>

          <LinearLayout
              android:id="@+id/btn_smart_clips"
              android:layout_width="0dp"
              android:layout_height="120dp"
              android:layout_weight="1"
              android:orientation="vertical"
              android:padding="18dp"
              android:gravity="center"
              android:clickable="true"
              android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔐" android:textSize="30sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Smart Clips" android:textSize="13sp" android:textStyle="bold"
                android:layout_marginTop="7dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Passwords &amp; Tokens" android:textSize="10sp" android:layout_marginTop="3dp"/>
          </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="10dp"/>

        <!-- Row 2: Typing Master | Dev Console -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

          <LinearLayout
              android:id="@+id/btn_typing_master"
              android:layout_width="0dp"
              android:layout_height="120dp"
              android:layout_weight="1"
              android:orientation="vertical"
              android:padding="18dp"
              android:gravity="center"
              android:clickable="true"
              android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚡" android:textSize="30sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Typing Master" android:textSize="13sp" android:textStyle="bold"
                android:layout_marginTop="7dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Speed Training" android:textSize="10sp" android:layout_marginTop="3dp"/>
          </LinearLayout>

          <View android:layout_width="10dp" android:layout_height="1dp"/>

          <LinearLayout
              android:id="@+id/btn_dev_console"
              android:layout_width="0dp"
              android:layout_height="120dp"
              android:layout_weight="1"
              android:orientation="vertical"
              android:padding="18dp"
              android:gravity="center"
              android:clickable="true"
              android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🖥" android:textSize="30sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dev Console" android:textSize="13sp" android:textStyle="bold"
                android:layout_marginTop="7dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="App Logs Overlay" android:textSize="10sp" android:layout_marginTop="3dp"/>
          </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="10dp"/>

        <!-- Row 3: System Console (full-width) -->
        <LinearLayout
            android:id="@+id/btn_system_console"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="🛡" android:textSize="26sp"/>

          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical"
              android:layout_marginStart="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="System Console" android:textSize="13sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Device-wide Logcat (requires Shizuku)" android:textSize="10sp"
                android:layout_marginTop="2dp"/>
          </LinearLayout>

          <LinearLayout
              android:id="@+id/shizuku_status_row"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:gravity="center_vertical">
            <View
                android:id="@+id/shizuku_launcher_dot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/dev_console_dot"
                android:layout_marginEnd="5dp"/>
            <TextView
                android:id="@+id/shizuku_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="…"
                android:textSize="9sp"/>
          </LinearLayout>

        </LinearLayout>

      </LinearLayout>

      <!-- ═══ TRY HERE CARD ═══════════════════════════════════════ -->
      <LinearLayout
          android:id="@+id/card_tryhere"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:layout_marginStart="16dp"
          android:layout_marginEnd="16dp"
          android:layout_marginTop="10dp"
          android:padding="18dp">

        <TextView
            android:id="@+id/launcher_tryhere_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/launcher_tryhere"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingBottom="10dp"/>

        <EditText
            android:id="@+id/launcher_tryhere_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:hint="@string/launcher_tryhere_hint"
            android:importantForAutofill="no"
            android:padding="14dp"
            android:textSize="14sp"/>

      </LinearLayout>

      <!-- ═══ FOOTER ════════════════════════════════════════════ -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="20dp"
          android:layout_marginTop="6dp"
          android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/launcher_sourcecode"
            android:textSize="11sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/launcher_repo_url"
            android:autoLink="web"
            android:linksClickable="true"
            android:textSize="11sp"
            android:layout_marginTop="4dp"/>

      </LinearLayout>

    </LinearLayout>

  </ScrollView>

</FrameLayout>
