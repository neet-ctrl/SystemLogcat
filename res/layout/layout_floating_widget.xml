<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- ══ COLLAPSED BUBBLE ══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/collapse_view"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:gravity="center"
        android:background="@drawable/float_bubble_bg"
        android:orientation="vertical"
        android:visibility="gone"
        android:elevation="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⌨"
            android:textSize="22sp"
            android:textColor="#FFCDD5FF"/>

    </LinearLayout>

    <!-- ══ EXPANDED GLASS PANEL ══════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/expanded_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/float_glass_bg"
        android:elevation="16dp"
        android:padding="0dp">

        <!-- ── Header bar — this whole block is the drag area ────── -->
        <LinearLayout
            android:id="@+id/header_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/widget_header_bg">

            <!-- Drag pill indicator -->
            <View
                android:id="@+id/drag_handle"
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/float_drag_handle"/>

            <!-- Button row inside header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/tv_widget_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Clipboard"
                    android:textSize="15sp"
                    android:textColor="#FFFFFFFF"
                    android:textStyle="bold"/>

                <!-- ⚙ Settings -->
                <Button
                    android:id="@+id/btn_widget_settings"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="⚙"
                    android:textSize="14sp"
                    android:textColor="#FFCDD5FF"
                    android:background="@drawable/widget_btn_inactive"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:layout_marginEnd="5dp"/>

                <!-- 📌 Pin to top toggle -->
                <Button
                    android:id="@+id/btn_pin_top"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="📌"
                    android:textSize="13sp"
                    android:textColor="#88CDD5FF"
                    android:background="@drawable/widget_btn_inactive"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:layout_marginEnd="5dp"/>

                <!-- ⌗ Collapse to bubble -->
                <Button
                    android:id="@+id/iv_collapse"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="⌗"
                    android:textSize="15sp"
                    android:textColor="#FFCDD5FF"
                    android:background="@drawable/widget_btn_inactive"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:layout_marginEnd="5dp"/>

                <!-- ✕ Close -->
                <Button
                    android:id="@+id/btn_close"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="✕"
                    android:textSize="13sp"
                    android:textColor="#FFFF6B6B"
                    android:background="@drawable/widget_btn_inactive"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>

            </LinearLayout>

        </LinearLayout>
        <!-- end header_bar -->

        <!-- ── Mode Tabs ────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="4dp">

            <Button
                android:id="@+id/btn_mode_history"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="📋  Clipboard"
                android:textSize="11sp"
                android:textColor="#FFFFFFFF"
                android:background="@drawable/widget_btn_active"
                android:padding="4dp"
                android:minWidth="0dp"
                android:minHeight="0dp"/>

            <View android:layout_width="8dp" android:layout_height="1dp"/>

            <Button
                android:id="@+id/btn_mode_smart"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="🔐  Smart Clips"
                android:textSize="11sp"
                android:textColor="#FFCDD5FF"
                android:background="@drawable/widget_btn_inactive"
                android:padding="4dp"
                android:minWidth="0dp"
                android:minHeight="0dp"/>

        </LinearLayout>

        <!-- ── Content List ─────────────────────────────────────── -->
        <ListView
            android:id="@+id/clip_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="6dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"/>

        <!-- ── Resize Grip (bottom-right corner) ────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="end|bottom"
            android:paddingEnd="0dp"
            android:paddingBottom="0dp">

            <TextView
                android:id="@+id/iv_resize"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="⤡"
                android:textSize="20sp"
                android:textColor="#DD818CF8"
                android:gravity="center"
                android:background="#331E2040"
                android:padding="8dp"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
