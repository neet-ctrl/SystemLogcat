<?xml version="1.0" encoding="utf-8"?>
<!-- Root must be match_parent so the ListView with layout_weight=1 gets proper height -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Collapsed view: single circular icon (original behaviour restored) -->
    <ImageView
        android:id="@+id/collapse_view"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_launcher_foreground"
        android:background="@drawable/doc_anim_circle"
        android:visibility="gone"
        android:contentDescription="Expand Clipboard History"/>

    <!-- Expanded view: full clipboard panel -->
    <LinearLayout
        android:id="@+id/expanded_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_rounded_card"
        android:elevation="8dp"
        android:padding="12dp">

        <!-- Header row: title + DevConsole button + collapse + close -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clipboard History"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"/>

            <!-- Dev Console button in header (same as in the fixed widget) -->
            <TextView
                android:id="@+id/btn_open_console"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🔧"
                android:textSize="18sp"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Open Dev Console"
                android:layout_marginEnd="4dp"/>

            <ImageView
                android:id="@+id/iv_collapse"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:padding="6dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Collapse"/>

            <Button
                android:id="@+id/btn_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="✕"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:textColor="#666666"
                android:textSize="18sp"
                android:minWidth="40dp"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <!-- Clip list fills remaining space -->
        <ListView
            android:id="@+id/clip_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"/>

        <!-- Resize handle -->
        <ImageView
            android:id="@+id/iv_resize"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|bottom"
            android:src="@android:drawable/ic_menu_directions"
            android:padding="8dp"
            android:background="#44000000"
            android:tint="#FFFFFF"
            android:contentDescription="Resize"/>

    </LinearLayout>
</FrameLayout>
