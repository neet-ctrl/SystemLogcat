<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!--
        Collapsed view: two small floating buttons side by side.
        Left  = Clipboard History (existing)
        Right = Developer Console (new)
    -->
    <LinearLayout
        android:id="@+id/collapse_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="@drawable/bg_rounded_card"
        android:elevation="8dp"
        android:padding="4dp">

        <!-- Clipboard button -->
        <ImageView
            android:id="@+id/btn_collapsed_clipboard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_launcher_foreground"
            android:background="@drawable/doc_anim_circle"
            android:contentDescription="Open Clipboard History"
            android:padding="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Dev Console button -->
        <TextView
            android:id="@+id/btn_collapsed_console"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🔧"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/dev_console_dot_btn"
            android:contentDescription="Open Developer Console"
            android:padding="4dp"/>

    </LinearLayout>

    <!-- Expanded clipboard panel (unchanged) -->
    <LinearLayout
        android:id="@+id/expanded_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_rounded_card"
        android:elevation="8dp"
        android:padding="12dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clipboard History"
                android:textSize="18sp"
                android:textColor="#333333"
                android:textStyle="bold"/>

            <!-- Open Dev Console button (inside expanded header) -->
            <TextView
                android:id="@+id/btn_open_console"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🔧"
                android:textSize="18sp"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Open Dev Console"
                android:layout_marginEnd="4dp"/>

            <ImageView
                android:id="@+id/iv_collapse"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:padding="6dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Collapse"/>

            <Button
                android:id="@+id/btn_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="✕"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:textColor="#666666"
                android:textSize="18sp"
                android:minWidth="40dp"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <ListView
            android:id="@+id/clip_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"/>

        <ImageView
            android:id="@+id/iv_resize"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|bottom"
            android:src="@android:drawable/ic_menu_directions"
            android:padding="8dp"
            android:background="#44000000"
            android:tint="#FFFFFF"
            android:contentDescription="Resize"/>

    </LinearLayout>
</FrameLayout>
