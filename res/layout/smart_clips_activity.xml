<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1565C0"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Smart Clips"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_toggle_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grid"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:padding="8dp"
            android:background="#33FFFFFF"/>

        <Button
            android:id="@+id/btn_lock_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lock: OFF"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:padding="8dp"
            android:layout_marginStart="8dp"
            android:background="#33FFFFFF"/>

        <Button
            android:id="@+id/btn_change_pin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PIN"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:padding="8dp"
            android:layout_marginStart="8dp"
            android:background="#33FFFFFF"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_unlock_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="#4CAF50"
        android:gravity="center"
        android:padding="4dp"
        android:visibility="gone"/>

    <EditText
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search clips..."
        android:padding="12dp"
        android:background="#FFFFFF"
        android:layout_margin="8dp"/>

    <ListView
        android:id="@+id/smart_clip_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:padding="8dp"/>

    <GridView
        android:id="@+id/smart_clip_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="2"
        android:horizontalSpacing="8dp"
        android:verticalSpacing="8dp"
        android:padding="8dp"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_add_smart_clip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add Clip"
            android:textColor="#FFFFFF"
            android:background="#1565C0"
            android:padding="16dp"/>
    </LinearLayout>
</LinearLayout>
